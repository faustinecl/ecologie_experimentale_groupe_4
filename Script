#Courbe de saturation des espèces 
#En x, nombre de sites échantillonnés (effort d’échantillonnage)
#en y, nombre de genres
#Plus on a de sites échantillonés, plus on a de genres ou d’espèces, jusqu'à arriver à saturation car on a un nombre fini de genres/espèces par parcelle. On regarde les genres car on a trop de NA pour les espèces qu’on n’a pas réussi à identifier. 

#Créer un tableau df_genre avec en colonne les différents genres et en ligne les conditions échantillons (parcelle)
#Un tableau pour la condition 1 et un pour la 9. Chaque tableau doit avoir 9 lignes (nombre de parcelles)


# ============================================================
# Logique :
# - réplicat = (n_bloc - 1) * 3 + n_repl
# (3 blocs x 3 réplicats = 9 réplicats par condition)
# - On pivote les genres en colonnes et on compte les individus
# - La colonne "Condition" reprend la valeur de "condition"
# ============================================================


# ------ Calcul du réplicat ------
df <- df %>%
mutate(replicat = (n_bloc - 1) * 3 + n_repl)
# ------ Comptage par (condition, réplicat, genre) ------
df_counts <- df %>%
group_by(condition, replicat, genre) %>%
summarise(n = n(), .groups = "drop")
# ------ Pivot : genres en colonnes ------
df_wide <- df_counts %>%
pivot_wider(
names_from = genre,
values_from = n,
values_fill = 0
)

# ------ Mise en forme finale ------
# Condition placée en dernière colonne (comme dans le tableau cible)
df_genre <- df_wide %>%
arrange(Condition, réplicat) %>%
relocate(Condition, .after = last_col())


#Création du tableau df_genre1 avec que les conditions 1, puis j'enlève la colonne condition pour qu'elle compte pas comme une espèce



df_genre1 <- df_genre %>%
  filter(Condition == 1) %>%
  select(-Condition)

df_genre9<- df_genre %>%
  filter(Condition == 9) %>%
  select(-Condition)
print(df_genre9)

# courbe d'accumulation d'espèces
courbe1 <- specaccum(df_genre1, method = "random", permutations = 1000)
courbe9 <- specaccum(df_genre9, method = "random", permutations = 1000)

plot(courbe1,
     col = "blue",
     lwd = 2,
     ci.type = "polygon",
     ci.col = rgb(0, 0, 1, 0.2),
     xlab = "Nombre de sites échantillonnés",
     ylab = "Nombre de genres",
     main = "Courbe de richesse cumulée",
     ylim = c(0, max(courbe9$richness) + 2))

plot(courbe9,
     add = TRUE,
     col = "red",
     lwd = 2,
     ci.type = "polygon",
     ci.col = rgb(1, 0, 0, 0.2))

legend("bottomright",
       legend = c("Contrôle", "Non-herbivorie"),
       col = c("blue", "red"),
       lwd = 2,
       bty = "n")


#Estimer/extrapoler le nombre maximum de genres qu'on aurait pu échantillonner
#Selon différentes méthodes

specpool(df_genre1)
specpool(df_genre9)

#Courbes extrapolées d'accumulation des genres : une courbe par méthode

pool1 <- poolaccum(df_genre1)
pool9 <- poolaccum(df_genre9)

plot(pool1)
plot(pool9)



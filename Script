# Transformer les “Na” du tableau Excel en vrais NA sur R 

df[df == "Na"] <- NA   

# Retirer les lignes qui sont des "constructions" (toiles, chaussettes) et non pas des "individus"

df = df[is.na(df$ind_constr) | df$ind_constr != "C" & df$ind_constr != "T",] 

### Description du tableau de données

unique(df$famille)         # Voir toutes les entrées dans la colonne famille = toutes les familles qu'on a répertoriées
length(unique(df$famille)) # Avoir le nombre total de famille qu'on a échantillonné
unique(df$genre)           # Pareil pour les genres
length(unique(df$genre))
summary(df)                # Résumé du tableau de données df


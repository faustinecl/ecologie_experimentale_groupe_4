# Test d'indépendance entre genre et condition
# Table de contingence genres x conditions
tab_genre_condition <- table(df$genre, df$condition)

# Test de Fisher avec simulation de Monte Carlo car pas condition d'application
test_fisher <- fisher.test(tab_genre_condition, simulate.p.value = TRUE, B = 10000)
# Extraire la p value, la statistique et n
test_fisher$p.value
test_fisher$statistic
sum(tab_genre_condition)
# Dépendance entre genre et condition


# Pour chaque genre, comparer le nombre moyen d'individu par parcelle entre les deux conditions
# Effectifs par genre x condition x parcelle
abondance_genre_cond_parc <- as.data.frame(table(df$genre, df$condition, df$n_bloc, df$n_repl))
colnames(abondance_genre_cond_parc) <- c("genre", "condition", "bloc", "jour", "n")

# Tests de Wilcoxon par genre (pas de t test car seulement 9 xi donc pas fiable de vérifier la normalité + beaucoup de genre à 0)
resultats_test_genre <- data.frame(genre = character(), statistique = numeric(), n = numeric(), p_value = numeric())
for (g in unique(abondance_genre_cond_parc$genre)) {
  sous_df <- abondance_genre_cond_parc[abondance_genre_cond_parc$genre == g, ]
  test <- wilcox.test(n ~ condition, data = sous_df)
  resultats_test_genre <- rbind(resultats_test_genre, data.frame(
    genre = g,
    statistique = test$statistic,
    n = nrow(sous_df),
    p_value = test$p.value
  ))
}
# Résultats
resultats_test_genre



### Sex ratio et impact des conditions sur celui-ci


## Tester la différence d'effectif entre male femelle au total

# Effectifs mâles/femelles par parcelle
effectifs_sexe_parc <- as.data.frame(table(df$sexe, df$condition, df$n_bloc, df$n_repl))
colnames(effectifs_sexe_parc) <- c("sexe", "condition", "bloc", "jour", "n")

# Boxplot
ggplot(effectifs_sexe_parc, aes(x = sexe, y = n, fill = sexe)) +
  geom_boxplot(outlier.shape = NA) +
  labs(title = "Effectifs mâles/femelles par parcelle", x = "Sexe", y = "Effectifs") +
  theme_minimal()

# Restructurer en format large pour le test apparié
effectifs_sexe_large <- spread(effectifs_sexe_parc, key = sexe, value = n)

# Vérifier la normalité des différences
shapiro.test(effectifs_sexe_large$F - effectifs_sexe_large$M)

# Donc t test
t.test(effectifs_sexe_large$F, effectifs_sexe_large$M, paired = TRUE)
# n
length(effectifs_sexe_large$F)
# Différence significative


## Pour chaque genre, comparer le nombre de moyen de mâle et de femelle par parcelle

# Effectifs sexe x genre
effectifs_sexe_genre <- as.data.frame(table(df$sexe, df$genre))
colnames(effectifs_sexe_genre) <- c("sexe", "genre", "n")

# Ordonner par abondance totale décroissante
effectifs_sexe_genre$genre <- reorder(effectifs_sexe_genre$genre, -effectifs_sexe_genre$n, FUN = sum)

# Barplot pour visualiser
ggplot(effectifs_sexe_genre, aes(x = genre, y = n, fill = sexe)) +
  geom_bar(stat = "identity", position = "dodge") +
  geom_text(aes(label = n), position = position_dodge(width = 0.9), vjust = -0.5, size = 3) +
  labs(title = "Effectifs mâles/femelles par genre", x = "Genre", y = "Effectifs", fill = "Sexe") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

# Effectifs mâles/femelles x genre x parcelle
abondance_sexe_genre <- as.data.frame(table(df$genre, df$sexe, df$n_bloc, df$n_repl))
colnames(abondance_sexe_genre) <- c("genre", "sexe", "bloc", "jour", "n")

# T tests ou Wilcoxon appariés par genre pour comparer les effectifs moyen de males et de femelles
resultats_sexe_genre <- data.frame(genre = character(), p_value = numeric(), test = character())
for (g in unique(df$genre)) {
  if (!is.na(g)) {
    sous_df <- abondance_sexe_genre[abondance_sexe_genre$genre == g, ]
    sous_df_large <- spread(sous_df, key = sexe, value = n)
    if (all(c("F", "M") %in% colnames(sous_df_large))) {
      differences <- sous_df_large$F - sous_df_large$M
      shapiro_ok <- tryCatch({
        shapiro.test(differences)$p.value > 0.05
      }, error = function(e) FALSE)
      if (shapiro_ok) {
        test <- t.test(sous_df_large$F, sous_df_large$M, paired = TRUE)
        test_utilise <- "t-test apparié"
      } else {
        test <- wilcox.test(sous_df_large$F, sous_df_large$M, paired = TRUE)
        test_utilise <- "Wilcoxon apparié"
      }
      resultats_sexe_genre <- rbind(resultats_sexe_genre, data.frame(genre = g, p_value = test$p.value, test = test_utilise))
    }
  }
}
# Résultats
resultats_sexe_genre
# remarque : NaN pour Uloborus car la différence entre F et M est toujours la même donc pas possible de réaliser le Wilcoxon


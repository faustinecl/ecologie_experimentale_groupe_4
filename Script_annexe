### Investigation d'un potentiel effet bloc

## Pour savoir s'il y a un effet bloc sur l'abondance et la présence des genres (test non paramétrique)
# Table de contingence genres x blocs
tab_genre_bloc <- table(df$genre, df$n_bloc)

# Test de Fisher avec simulation de Monte Carlo car présence de 0 dans le tableau de contingence
fisher.test(tab_genre_bloc, simulate.p.value = TRUE, B = 10000)
# pas de différence significative

## Pour savoir s il y a un effet bloc sur l abondance des individus
# Abondance par bloc x condition x jour
abondance_bloc_cond_jour <- as.data.frame(table(df$n_bloc, df$condition, df$n_repl))
colnames(abondance_bloc_cond_jour) <- c("bloc", "condition", "jour", "abondance")
# Moyenne par bloc pour avoir une idée
aggregate(abondance ~ bloc, data = abondance_bloc_cond_jour, FUN = mean)
# ANOVA
mod <- aov(abondance ~ bloc, data = abondance_bloc_cond_jour)
# Vérifier la normalité des résidus
shapiro.test(residuals(mod))
# Vérifier l'homogénéité des variances
bartlett.test(abondance ~ bloc, data = abondance_bloc_cond_jour)

# résultats du test
summary(mod)
# Pas de différence significative
# On considère donc les blocs comme de vrais réplicats

### Evaluation de l'impact des deux conditions sur les populations

## Impact sur l'abondance totale

# Effectifs totaux par condition x parcelle
abondance_totale <- as.data.frame(table(df$condition, df$n_bloc, df$n_repl))
colnames(abondance_totale) <- c("condition", "bloc", "jour", "n")

# Boxplot pour visualiser
ggplot(abondance_totale, aes(x = condition, y = n, fill = condition)) +
  geom_boxplot() +
  labs(title = "Abondance totale par condition", x = "Conditions", y = "Effectifs") +
  scale_x_discrete(labels = c("1" = "Contrôle", "9" = "Protection herbivorie")) +
  theme_minimal() +
  theme(legend.position = "none")

# t test avec vérification des conditions (shapiro) sur les effectifs moyens par parcelles en fonction de la condition
shapiro.test(residuals(aov(n ~ condition, data = abondance_totale)))
t.test(n ~ condition, data = abondance_totale)
# Pas de différence d'abondance significative entre les conditions

## Impact sur les genres

# Effectifs des genres par conditions
effectifs_genre_cond <- as.data.frame(table(df$genre, df$condition))
colnames(effectifs_genre_cond) <- c("genre", "condition", "n")

# Nommer
effectifs_genre_cond$condition <- factor(effectifs_genre_cond$condition,
                                         levels = c("1", "9"),
                                         labels = c("Contrôle", "Protection herbivorie"))

# Ordonner par abondance totale décroissante
effectifs_genre_cond$genre <- reorder(effectifs_genre_cond$genre, -effectifs_genre_cond$n, FUN = sum)

# L'histogramme par effectifs
ggplot(effectifs_genre_cond, aes(x = genre, y = n, fill = condition)) +
  geom_bar(stat = "identity", position = "dodge") +
  geom_text(aes(label = n), position = position_dodge(width = 0.9), vjust = -0.5, size = 3) +
  labs(title = "Effectifs des genres par condition", x = "Genres", y = "Effectifs", fill = "Conditions") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

# Construire l'histogramme par proportion pour une autre représentation
# Effectif des genres par condition
effectifs_genre_cond_prop <- as.data.frame(table(df$genre, df$condition))
colnames(effectifs_genre_cond_prop) <- c("genre", "condition", "n")

# Nommer
effectifs_genre_cond_prop$condition <- factor(effectifs_genre_cond_prop$condition,

### Simple description
# Calculer les effectifs totaux par condition
effectifs <- as.data.frame(table(df$condition))
colnames(effectifs) <- c("Condition", "n")

# Nommer
effectifs$Condition <- factor(effectifs$Condition, 
                              levels = c("1", "9"), 
                              labels = c("Contrôle", "Protection herbivorie"))

# Barplot
ggplot(effectifs, aes(x = Condition, y = n, fill = Condition)) +
  geom_bar(stat = "identity") +
  geom_text(aes(label = n), vjust = -0.5, size = 4) +
  labs(title = "Effectifs par condition", x = "Condition", y = "Effectifs") +
  theme_minimal()


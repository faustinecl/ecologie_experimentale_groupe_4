## Pour chaque genre, tester la dépendance entre sexe et condition

# Test de Chi2 ou Fisher par genre seulement pour les genres présents aux deux conditions et pour les deux sexes
resultats_sexe_genre_cond <- data.frame(genre = character(), p_value = numeric(), test = character())
for (g in unique(df$genre)) {
  if (!is.na(g)) {
    sous_df <- df[df$genre == g, ]
    tab <- table(sous_df$sexe, sous_df$condition)
    if (nrow(tab) == 2 & ncol(tab) == 2) {
      if (all(chisq.test(tab)$expected >= 5)) {
        test <- chisq.test(tab)
        test_utilise <- "Chi2"
      } else {
        test <- fisher.test(tab)
        test_utilise <- "Fisher"
      }
      resultats_sexe_genre_cond <- rbind(resultats_sexe_genre_cond, data.frame(genre = g, p_value = test$p.value, test = test_utilise))
    }
  }
}

# Résultats
resultats_sexe_genre_cond


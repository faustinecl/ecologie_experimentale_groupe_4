df = read.csv( ‘emplacement/Data.csv, sep=‘,’)

library(vegan)
library(tidyverse)
library(unmarked)
library(AICcmodavg)

### Edition du tableau de données

# Transformer les “Na” du tableau Excel en vrais NA sur R 

df[df == "Na"] <- NA   

# Retirer les lignes qui sont des "constructions" (toiles, chaussettes) et non pas des "individus"

df = df[is.na(df$ind_constr) | df$ind_constr != "C" & df$ind_constr != "T",] 

